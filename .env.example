# Trail - Environment Variables
# Copy this file to .env and fill in your actual values

# PostgreSQL Connection
DATABASE_URL=postgresql://ariadne:yourpassword@localhost:5432/ariadne

# Redis Connection
REDIS_URL=redis://localhost:6379/0

# GitHub API Token (classic or fine-grained PAT)
GITHUB_TOKEN=ghp_your_github_token_here

# Notion Integration Token
NOTION_TOKEN=ntn_your_notion_token_here

# OpenRouter API (Phase 3: Report Generation)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_TIMEOUT=60

# Slack Webhook (Phase 4: Escalation Engine, Phase 6.5: Plan Adjustment)
# Create at: https://my.slack.com/services/new/incoming-webhook/
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
